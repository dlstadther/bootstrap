#!/usr/bin/env bash
# Sends macOS notifications for Claude Code hook events (Stop, Notification).
# Wired as a hook in ~/.claude/settings.json; reads JSON payload from stdin.

payload=$(cat)

session_id=$(echo "$payload" | jq -r '.session_id // "unknown"')
hook_event=$(echo "$payload" | jq -r '.hook_event_name // "unknown"')
message=$(echo "$payload" | jq -r '.message // ""')
cwd_project=$(echo "$payload" | jq -r '.cwd // ""' | xargs basename 2>/dev/null || true)

# Capture tmux target and client at hook-fire time.
# TMUX_PANE is not always inherited by hook subprocesses, so fall back to
# walking the process tree to find which pane owns the claude process.
tmux_target=""
tmux_client=""
tmux_session=""
if [[ -n "${TMUX_PANE:-}" ]]; then
    tmux_target=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null || true)
    tmux_client=$(tmux display-message -p -t "$TMUX_PANE" '#{client_name}' 2>/dev/null || true)
    tmux_session=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}' 2>/dev/null || true)
fi
if [[ -z "$tmux_session" ]] && command -v tmux &>/dev/null && tmux ls &>/dev/null 2>&1; then
    _pid=$$
    _panes=$(tmux list-panes -a -F '#{pane_pid} #{session_name}:#{window_index}.#{pane_index}' 2>/dev/null || true)
    while [[ -n "$_pid" && "$_pid" -gt 1 && -n "$_panes" ]]; do
        _match=$(awk -v p="$_pid" '$1==p{print $2; exit}' <<< "$_panes")
        if [[ -n "$_match" ]]; then
            tmux_target="$_match"
            tmux_session="${_match%%:*}"
            tmux_client=$(tmux display-message -t "$tmux_target" -p '#{client_name}' 2>/dev/null || true)
            break
        fi
        _pid=$(ps -o ppid= -p "$_pid" 2>/dev/null | tr -d '[:space:]')
        [[ "$_pid" =~ ^[0-9]+$ ]] || break
    done
    unset _pid _panes _match
fi

# Write pending-notification flag file so tmux status and popup can read it
if [[ -n "$tmux_session" ]]; then
    pending_dir="${HOME}/.local/share/claude-pending"
    mkdir -p "$pending_dir"
    printf '{"project":"%s","target":"%s","timestamp":%s}\n' \
        "$cwd_project" "$tmux_target" "$(date +%s)" \
        > "${pending_dir}/${tmux_session}"
fi

# Build notification fields
if [[ -n "$cwd_project" && -n "$tmux_target" ]]; then
    title="Claude Code — $cwd_project [$tmux_target]"
elif [[ -n "$cwd_project" ]]; then
    title="Claude Code — $cwd_project"
elif [[ -n "$tmux_target" ]]; then
    title="Claude Code — $tmux_target"
else
    title="Claude Code"
fi

[[ ${#message} -gt 120 ]] && message="${message:0:120}…"
[[ -z "$message" ]] && message="Session event"

# Click action: activate Ghostty, then switch the specific tmux client to the right pane
if [[ -n "$tmux_target" && -n "$tmux_client" ]]; then
    execute="osascript -e 'tell application \"Ghostty\" to activate' && tmux switch-client -c '$tmux_client' -t '$tmux_target'"
else
    execute="osascript -e 'tell application \"Ghostty\" to activate'"
fi

terminal-notifier \
    -title "$title" \
    -subtitle "$hook_event" \
    -message "$message" \
    -execute "$execute" \
    -group "claude-${session_id}" \
    -sound default \
    2>/dev/null || true

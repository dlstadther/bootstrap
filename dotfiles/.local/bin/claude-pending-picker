#!/usr/bin/env bash
# tmux popup: browse and act on pending Claude notifications
# flag files live in ~/.local/share/claude-pending/<session_name>
# Stale entries (session no longer alive) show [gone] and dismiss on Enter.

set -euo pipefail

PENDING_DIR="${HOME}/.local/share/claude-pending"

build_list() {
    [[ -d "$PENDING_DIR" ]] || return 0
    local now active_sessions
    now=$(date +%s)
    active_sessions=$(tmux ls -F '#{session_name}' 2>/dev/null || true)
    for flag in "${PENDING_DIR}"/*; do
        [[ -f "$flag" ]] || continue
        local session project target ts elapsed elapsed_str status
        session=$(basename "$flag")
        project=$(jq -r '.project // "unknown"' "$flag" 2>/dev/null)
        target=$(jq -r '.target // ""' "$flag" 2>/dev/null)
        ts=$(jq -r '.timestamp // 0' "$flag" 2>/dev/null)
        elapsed=$(( now - ts ))
        if (( elapsed < 60 )); then
            elapsed_str="${elapsed}s ago"
        elif (( elapsed < 3600 )); then
            elapsed_str="$(( elapsed / 60 ))m ago"
        else
            elapsed_str="$(( elapsed / 3600 ))h $(( (elapsed % 3600) / 60 ))m ago"
        fi
        if echo "$active_sessions" | grep -qx "$session"; then
            status="live"
        else
            status="stale"
            elapsed_str="[gone] ${elapsed_str}"
        fi
        printf '%-16s\t%-30s\t%s\t%s\t%s\n' "$elapsed_str" "$project" "$session" "$target" "$status"
    done
}

case "${1:-}" in
    --list)
        build_list
        exit 0
        ;;
    --dismiss)
        rm -f "${PENDING_DIR}/${2:?missing session}"
        exit 0
        ;;
    --dismiss-all)
        find "${PENDING_DIR}" -maxdepth 1 -type f -delete 2>/dev/null || true
        exit 0
        ;;
esac

list=$(build_list)

if [[ -z "$list" ]]; then
    printf '\n  Claude Pending  —  no pending sessions\n\n  press any key to close\n'
    read -rsn1 2>/dev/null || true
    exit 0
fi

selected=$(printf '%s' "$list" | fzf \
    --delimiter $'\t' \
    --with-nth '1,2' \
    --no-sort \
    --ansi \
    --header " Claude Pending"$'\n'"  Enter: switch (dismiss if gone)  d: dismiss  D: dismiss all  Esc: close" \
    --preview "tmux capture-pane -t {4} -p 2>/dev/null | tail -50 || echo '(session no longer active)'" \
    --preview-window 'right:55%:wrap' \
    --bind "d:execute-silent($0 --dismiss {3})+reload($0 --list)" \
    --bind "D:execute-silent($0 --dismiss-all)+abort" \
    --bind 'esc:abort' \
    --bind 'q:abort' \
    || true)

if [[ -n "$selected" ]]; then
    session=$(printf '%s' "$selected" | cut -f3)
    target=$(printf '%s' "$selected" | cut -f4)
    status=$(printf '%s' "$selected" | cut -f5)
    rm -f "${PENDING_DIR}/${session}"
    [[ "$status" == "live" ]] && tmux switch-client -t "${target:-$session}"
fi

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "90",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "MAX_THINKING_TOKENS": "10000"
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls:*)",
      "Bash(ps *)",
      "Bash(python3 *)",
      "Bash(sed *)",
      "Bash(sleep *)",
      "Bash(tail *)",
      "Bash(timeout *)",
      "Bash(wc:*)",
      "Bash(which *)",
      "Bash(git add*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git commit*)",
      "Bash(git diff*)",
      "Bash(git fetch*)",
      "Bash(git log*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git remote*)",
      "Bash(git show*)",
      "Bash(git stash*)",
      "Bash(git status*)",
      "Bash(git symbolic-ref*)",
      "Bash(git worktree*)",
      "Bash(just:*)",
      "Bash(make:*)",
      "Bash(mise *)",
      "Bash(gh api*)",
      "Bash(gh issue list*)",
      "Bash(gh issue status*)",
      "Bash(gh issue view*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr create*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr list*)",
      "Bash(gh pr status*)",
      "Bash(gh pr view*)",
      "Bash(gh release list*)",
      "Bash(gh release view*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh run watch*)",
      "Bash(gh workflow list*)",
      "Bash(gh workflow view*)",
      "Bash(gc *)",
      "Bash(bd add*)",
      "Bash(bd agents-md*)",
      "Bash(bd assign*)",
      "Bash(bd backup*)",
      "Bash(bd children*)",
      "Bash(bd close*)",
      "Bash(bd comments*)",
      "Bash(bd count*)",
      "Bash(bd create*)",
      "Bash(bd dep*)",
      "Bash(bd diff*)",
      "Bash(bd edit*)",
      "Bash(bd epic*)",
      "Bash(bd gate*)",
      "Bash(bd graph*)",
      "Bash(bd history*)",
      "Bash(bd label*)",
      "Bash(bd lint*)",
      "Bash(bd list*)",
      "Bash(bd mol*)",
      "Bash(bd note*)",
      "Bash(bd promote*)",
      "Bash(bd q*)",
      "Bash(bd query*)",
      "Bash(bd reopen*)",
      "Bash(bd search*)",
      "Bash(bd set-state*)",
      "Bash(bd show*)",
      "Bash(bd stale*)",
      "Bash(bd state*)",
      "Bash(bd status*)",
      "Bash(bd statuses*)",
      "Bash(bd swarm*)",
      "Bash(bd todo*)",
      "Bash(bd types*)",
      "Bash(bd update*)"
    ],
    "ask": [
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(git tag*)",
      "Bash(bd branch*)",
      "Bash(bd delete*)",
      "Bash(bd duplicate*)",
      "Bash(bd duplicates*)",
      "Bash(bd export*)",
      "Bash(bd federation*)",
      "Bash(bd find-duplicates*)",
      "Bash(bd import*)",
      "Bash(bd move*)",
      "Bash(bd refile*)",
      "Bash(bd restore*)",
      "Bash(bd supersede*)",
      "Bash(bd vc*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "/Users/dstadther/.local/share/mise/shims/ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "caveman@caveman": true,
    "team-update-report@inmarket-skills": true,
    "circleci-logs@inmarket-skills": true
  },
  "tui": "fullscreen",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}

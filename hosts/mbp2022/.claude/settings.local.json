{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "/Users/dlstadther/.local/share/mise/shims/ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "agentsmith@dlstadther-agentsmith": true,
    "wasteland@gastownhall-marketplace": true
  },
  "extraKnownMarketplaces": {
    "dlstadther-agentsmith": {
      "source": {
        "source": "directory",
        "path": "/Users/dlstadther/code/agentsmith"
      }
    },
    "gastownhall-marketplace": {
      "source": {
        "source": "github",
        "repo": "gastownhall/marketplace"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
